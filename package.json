{
  "name": "@huhuhang/multipull",
  "version": "0.1.4",
  "description": "Pull many Git repositories safely from one CLI.",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/huhuhang/multipull.git"
  },
  "bugs": {
    "url": "https://github.com/huhuhang/multipull/issues"
  },
  "homepage": "https://github.com/huhuhang/multipull#readme",
  "bin": {
    "multipull": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && chmod +x dist/cli.js",
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "check": "npm run typecheck && npm run test && npm run build",
    "prepack": "npm run build"
  },
  "keywords": [
    "git",
    "pull",
    "cli",
    "monorepo",
    "repositories"
  ],
  "author": "huhuhang",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "commander": "^14.0.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsx": "^4.20.0",
    "typescript": "^5.8.0",
    "vitest": "^4.1.9"
  }
}
